DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dubaipro?schema=public"

# Secret used to sign JWT session cookies (HS256).
# Generate one with, e.g. PowerShell:
#   [Convert]::ToBase64String([byte[]](1..48 | ForEach-Object { Get-Random -Maximum 256 }))
# or on Linux/macOS:
#   openssl rand -base64 48
# MUST be at least 16 characters; 32+ is strongly recommended in production.
AUTH_SECRET="replace-me-with-a-long-random-string-at-least-32-chars"

# --- Payments (Stripe) -----------------------------------------------------
# Stripe secret key. Use sk_test_... for development, sk_live_... for prod.
# Get both keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."

# Stripe webhook signing secret. Create the endpoint first:
#   Dashboard → Developers → Webhooks → Add endpoint
#   URL: https://<your-domain>/api/payment/webhook?provider=stripe
#   Events: checkout.session.completed, checkout.session.async_payment_succeeded,
#           checkout.session.async_payment_failed, checkout.session.expired
# For local development, forward events via Stripe CLI:
#   stripe listen --forward-to http://localhost:3000/api/payment/webhook?provider=stripe
# The CLI prints a `whsec_...` secret you paste here.
STRIPE_WEBHOOK_SECRET="whsec_..."

# Public base URL used to build success/cancel redirect URLs.
# In production set to your deployed origin; in dev this falls back to the
# request's host header if unset.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=dubaipro.ae@gmail.com
SMTP_PASS=abcdefghijklmnop
SMTP_FROM=yourgmail@gmail.com
CRON_SECRET=mysupersecret123

# --- Auto-translation ------------------------------------------------------
# Pipeline used by `lib/i18n/translate.ts`. Every dynamic string the
# storefront renders (homepage section copy, dynamic content, …) is
# translated once per (text, locale) pair and cached in the
# `Translation` table. Subsequent visits read from the cache only.
#
# Provider options:
#   none           - no provider; pages render in the source language
#                    (graceful degradation; admins can still hand-fill
#                    the cache table directly).
#   libretranslate - free / self-hostable engine. Set TRANSLATE_API_URL
#                    to your instance (e.g. https://libretranslate.com).
#                    TRANSLATE_API_KEY is optional depending on the host.
#   openai         - uses gpt-4o-mini (override with TRANSLATE_OPENAI_MODEL)
#                    via OPENAI_API_KEY. Highest quality, recommended for
#                    production.
#
# If TRANSLATE_PROVIDER is unset but OPENAI_API_KEY is present, the
# pipeline auto-selects `openai`.
TRANSLATE_PROVIDER=none
TRANSLATE_SOURCE_LOCALE=en
TRANSLATE_API_URL=
TRANSLATE_API_KEY=
TRANSLATE_OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# --- AI Vision (Media SEO) --------------------------------------------------
# Enables AI-powered alt text / keywords / caption generation for images.
# If MEDIA_AI_API_KEY is unset, falls back to OPENAI_API_KEY automatically.
#
# Provider options: openai | gemini | claude
# MEDIA_AI_PROVIDER=openai
# MEDIA_AI_API_KEY=         (leave blank to reuse OPENAI_API_KEY)
# MEDIA_AI_MODEL=gpt-4o     (optional — defaults to provider default)
#
# Set to true to automatically generate SEO metadata on every image upload.
MEDIA_AI_AUTO_GENERATE=true